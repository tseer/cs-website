---
layout: null
permalink: /ai-search.json
---
{
  {% assign site_root_url = '/' | absolute_url %}
  {% assign empty_array = "" | split: "" %}
  "site": {
    "name": "UMass Boston Computer Science Department",
    "url": {{ site_root_url | jsonify }}
  },
  "pages": [
    {% assign important_page_urls = "/academics/|/people/|/research/|/resources/|/admissions|/course-schedule|/cs-minor|/student-funding|/alumni|/faculty|/staff|/funding|/groups|/info|/about/|/contact-us|/department|/facilities|/dei|/getting-here|/news-and-events/|/answers-to-faqs|/office-hours|/cs-department-it-policies|/chimera/|/dreamspark-microsoft-imagine" | split: "|" %}
    {% assign first_page_written = false %}
    {% for item_url in important_page_urls %}
    {% assign page_item = site.pages | where: "url", item_url | first %}
    {% if page_item %}
    {% unless first_page_written %}{% assign first_page_written = true %}{% else %},{% endunless %}
    {
      "title": {{ page_item.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ page_item.url | absolute_url | jsonify }}{% if page_item.summary %},
      "summary": {{ page_item.summary | strip_html | normalize_whitespace | jsonify }}{% endif %}{% assign page_item_description = page_item.summary | default: page_item.description %}{% if page_item_description %},
      "description": {{ page_item_description | strip_html | normalize_whitespace | jsonify }}{% endif %}{% if page_item.keywords %},
      "keywords": {{ page_item.keywords | jsonify }}{% endif %}{% if page_item.aliases %},
      "aliases": {{ page_item.aliases | jsonify }}{% endif %}{% if page_item.related_people %},
      "related_people": {{ page_item.related_people | jsonify }}{% endif %}{% if page_item.related_courses %},
      "related_courses": {% include related-course-codes.json codes=page_item.related_courses %}{% endif %}{% if page_item.related_groups %},
      "related_groups": {{ page_item.related_groups | jsonify }}{% endif %}{% if page_item.related_programs %},
      "related_programs": {{ page_item.related_programs | jsonify }}{% endif %}{% if page_item.related_topics %},
      "related_topics": {{ page_item.related_topics | jsonify }}{% endif %}{% if page_item.audience %},
      "audience": {{ page_item.audience | jsonify }}{% endif %}{% if page_item.action_phrases %},
      "action_phrases": {{ page_item.action_phrases | jsonify }}{% endif %},
      "content_excerpt": {{ page_item.content | markdownify | strip_html | normalize_whitespace | truncate: 320 | jsonify }}
    }
    {% endif %}
    {% endfor %}
    {% assign job_pages = site.pages | default: empty_array | where_exp: "item", "item.url contains '/news_and_events/jobs_and_internships/'" | sort: "url" %}
    {% for resource_page in job_pages %}
    {% if first_page_written %},{% endif %}{% assign first_page_written = true %}
    {
      "title": {{ resource_page.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ resource_page.url | absolute_url | jsonify }},
      "summary": {{ resource_page.summary | default: resource_page.description | default: resource_page.content | markdownify | strip_html | normalize_whitespace | truncate: 220 | jsonify }},
      "description": {{ resource_page.summary | default: resource_page.description | default: resource_page.content | markdownify | strip_html | normalize_whitespace | truncate: 320 | jsonify }}{% if resource_page.keywords %},
      "keywords": {{ resource_page.keywords | jsonify }}{% endif %}{% if resource_page.aliases %},
      "aliases": {{ resource_page.aliases | jsonify }}{% endif %}{% if resource_page.related_people %},
      "related_people": {{ resource_page.related_people | jsonify }}{% endif %}{% if resource_page.related_courses %},
      "related_courses": {% include related-course-codes.json codes=resource_page.related_courses %}{% endif %}{% if resource_page.related_groups %},
      "related_groups": {{ resource_page.related_groups | jsonify }}{% endif %}{% if resource_page.related_programs %},
      "related_programs": {{ resource_page.related_programs | jsonify }}{% endif %}{% if resource_page.related_topics %},
      "related_topics": {{ resource_page.related_topics | jsonify }}{% endif %},
      "content_excerpt": {{ resource_page.content | markdownify | strip_html | normalize_whitespace | truncate: 320 | jsonify }}
    }
    {% endfor %}
  ],
  "courses": [
    {% assign course_pages = site.pages | default: empty_array | where_exp: "item", "item.course_code" | sort: "course_code" %}
    {% for course in course_pages %}
    {
      "course_code": {{ course.course_code | jsonify }},
      "course_name": {{ course.course_name | jsonify }},
      "title": {{ course.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ course.url | absolute_url | jsonify }},
      "summary": {{ course.summary | default: "" | strip_html | normalize_whitespace | jsonify }},
      "description": {{ course.description | strip_html | normalize_whitespace | jsonify }},
      "aliases": {{ course.aliases | jsonify }},
      "prerequisites": {{ course.prerequisites | jsonify }},
      "co_requisites": {{ course.co_requisites | jsonify }},
      "keywords": {{ course.keywords | jsonify }},
      "related_people": {{ course.related_people | jsonify }},
      "related_courses": {% include related-course-codes.json codes=course.related_courses %},
      "related_groups": {{ course.related_groups | jsonify }},
      "related_programs": {{ course.related_programs | jsonify }},
      "related_topics": {{ course.related_topics | jsonify }},
      "audience": {{ course.audience | jsonify }},
      "action_phrases": {{ course.action_phrases | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "programs": [
    {% assign program_urls = "/undergraduate-programs|/graduate-programs|/honors-programs|/certificate-programs|/cs_ba|/cs_bs|/it_bs|/cs_ms|/cs_phd" | split: "|" %}
    {% assign first_program_written = false %}
    {% for item_url in program_urls %}
    {% assign program_page = site.pages | where: "url", item_url | first %}
    {% if program_page %}
    {% unless first_program_written %}{% assign first_program_written = true %}{% else %},{% endunless %}
    {
      "title": {{ program_page.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ program_page.url | absolute_url | jsonify }},
      "summary": {{ program_page.summary | default: "" | strip_html | normalize_whitespace | jsonify }},
      "description": {{ program_page.summary | default: program_page.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "keywords": {{ program_page.keywords | jsonify }},
      "aliases": {{ program_page.aliases | jsonify }},
      "related_people": {{ program_page.related_people | jsonify }},
      "related_courses": {% include related-course-codes.json codes=program_page.related_courses %},
      "related_groups": {{ program_page.related_groups | jsonify }},
      "related_programs": {{ program_page.related_programs | jsonify }},
      "related_topics": {{ program_page.related_topics | jsonify }},
      "audience": {{ program_page.audience | jsonify }},
      "action_phrases": {{ program_page.action_phrases | jsonify }}
    }
    {% endif %}
    {% endfor %}
  ],
  "people": [
    {% assign people_pages = site.people | default: empty_array | sort: "person_name" %}
    {% for person in people_pages %}
    {
      "name": {{ person.person_name | default: person.title | strip_html | normalize_whitespace | jsonify }},
      "title": {{ person.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ person.url | absolute_url | jsonify }},
      "summary": {{ person.summary | default: "" | strip_html | normalize_whitespace | jsonify }},
      "description": {{ person.summary | default: person.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "job_title": {{ person.job_title | default: "" | jsonify }},
      "keywords": {{ person.keywords | jsonify }},
      "aliases": {{ person.aliases | jsonify }},
      "related_people": {{ person.related_people | jsonify }},
      "related_courses": {% include related-course-codes.json codes=person.related_courses %},
      "related_groups": {{ person.related_groups | jsonify }},
      "related_programs": {{ person.related_programs | jsonify }},
      "related_topics": {{ person.related_topics | default: person.research_areas | jsonify }},
      "audience": {{ person.audience | jsonify }},
      "action_phrases": {{ person.action_phrases | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "groups": [
    {% assign group_pages = site.groups | default: empty_array | sort: "group_name" %}
    {% for group in group_pages %}
    {
      "name": {{ group.group_name | default: group.title | strip_html | normalize_whitespace | jsonify }},
      "title": {{ group.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ group.url | absolute_url | jsonify }},
      "summary": {{ group.summary | default: "" | strip_html | normalize_whitespace | jsonify }},
      "description": {{ group.summary | default: group.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "aliases": {{ group.aliases | jsonify }},
      "related_people": {{ group.related_people | default: group.lead_people | jsonify }},
      "related_courses": {% include related-course-codes.json codes=group.related_courses %},
      "related_groups": {{ group.related_groups | jsonify }},
      "related_programs": {{ group.related_programs | jsonify }},
      "related_topics": {{ group.related_topics | jsonify }},
      "keywords": {{ group.keywords | jsonify }},
      "audience": {{ group.audience | jsonify }},
      "action_phrases": {{ group.action_phrases | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "posts": [
    {% assign all_posts = site.posts | default: empty_array | sort: "date" | reverse %}
    {% for post in all_posts %}
    {
      "title": {{ post.title | strip_html | normalize_whitespace | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }}{% if post.categories and post.categories.first %},
      "category": {{ post.categories.first | jsonify }}{% endif %},
      "description": {{ post.description | default: post.excerpt | default: post.content | markdownify | strip_html | normalize_whitespace | truncate: 320 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
