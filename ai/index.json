---
layout: null
permalink: /ai/index.json
---
{
  {% assign site_root_url = '/' | absolute_url %}
  {% assign empty_array = "" | split: "" %}
  {% assign offerings_data = site.data.course_offerings %}
  {% assign offering_relationships = offerings_data.relationships %}
  {% assign external_people = site.data.external_faculty_profiles.people %}
  "site": {
    "name": {{ site.title | jsonify }},
    "url": {{ site_root_url | jsonify }}
  },
  "entities": [
    {
      "id": "department:computer-science",
      "type": "department",
      "title": {{ site.department_name | jsonify }},
      "summary": {{ page.summary | default: site.description | strip_html | normalize_whitespace | jsonify }},
      "url": {{ '/' | absolute_url | jsonify }},
      "keywords": {{ "Computer Science Department|UMass Boston|Computer Science|Information Technology" | split: "|" | jsonify }},
      "aliases": {{ "Computer Science Department|UMass Boston Computer Science|UMass Boston CS|CS Department" | split: "|" | jsonify }},
      "related_people": [],
      "related_courses": [],
      "related_groups": [],
      "related_programs": [],
      "related_topics": {{ "computer science|information technology|research|teaching" | split: "|" | jsonify }},
      "nav_label": "Home",
      "section_name": "Home",
      "parent_section": null,
      "is_landing_page": true,
      "menu_keywords": {{ "home|computer science department" | split: "|" | jsonify }}
    }{% assign important_page_urls = "/academics/|/people/|/research/|/resources/|/admissions|/course-schedule|/cs-minor|/student-funding|/alumni|/faculty|/staff|/funding|/groups|/research/chimera/|/info|/about/|/contact-us|/department|/facilities|/dei|/getting-here|/news-and-events/|/answers-to-faqs|/office-hours|/cs-department-it-policies|/dreamspark-microsoft-imagine|/ai-assistant" | split: "|" %}{% for item_url in important_page_urls %}{% assign page_item = site.pages | where: "url", item_url | first %}{% if page_item %}{% assign page_type = page_item.entity_type | default: "" %}{% if page_type == "" %}{% if page_item.url == "/facilities" or page_item.url == "/research/chimera/" %}{% assign page_type = "facility" %}{% elsif page_item.url == "/resources/" or page_item.url == "/answers-to-faqs" or page_item.url == "/office-hours" or page_item.url == "/cs-department-it-policies" or page_item.url == "/info" or page_item.url == "/student-funding" or page_item.url == "/dreamspark-microsoft-imagine" or page_item.url == "/ai-assistant" %}{% assign page_type = "resource" %}{% else %}{% assign page_type = "page" %}{% endif %}{% endif %}{% assign page_slug = page_item.url | replace: "/", "" %},
    {
      "id": {{ page_type | append: ":" | append: page_slug | jsonify }},
      "type": {{ page_type | jsonify }},
      "title": {{ page_item.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ page_item.summary | default: page_item.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "url": {{ page_item.url | absolute_url | jsonify }},
      "keywords": {% if page_item.keywords %}{{ page_item.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if page_item.aliases %}{{ page_item.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% if page_item.related_people %}{{ page_item.related_people | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% include related-course-codes.json codes=page_item.related_courses %},
      "related_groups": {% if page_item.related_groups %}{{ page_item.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if page_item.related_programs %}{{ page_item.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if page_item.related_topics %}{{ page_item.related_topics | jsonify }}{% else %}[]{% endif %},
      "nav_label": {{ page_item.nav_label | default: nil | jsonify }},
      "section_name": {{ page_item.section_name | default: nil | jsonify }},
      "parent_section": {{ page_item.parent_section | default: nil | jsonify }},
      "is_landing_page": {% if page_item.is_landing_page %}true{% else %}false{% endif %},
      "menu_keywords": {% if page_item.menu_keywords %}{{ page_item.menu_keywords | jsonify }}{% else %}[]{% endif %}
    }{% endif %}{% endfor %}{% assign course_pages = site.pages | default: empty_array | where_exp: "item", "item.course_code" | sort: "course_code" %}{% for course in course_pages %}{% assign course_relationships = offering_relationships.courses[course.course_code] %}{% assign course_offerings = offerings_data.course_index[course.course_code] | default: empty_array %}{% capture course_instructors_blob %}{% for offering in course_offerings %}{% if offering.instructor %}{{ offering.instructor }}||{% endif %}{% endfor %}{% endcapture %}{% assign course_instructors = course_instructors_blob | split: "||" | uniq %}{% capture course_terms_blob %}{% for offering in course_offerings %}{% if offering.term_label %}{{ offering.term_label }}||{% endif %}{% endfor %}{% endcapture %}{% assign course_terms = course_terms_blob | split: "||" | uniq %}{% capture course_years_blob %}{% for offering in course_offerings %}{% if offering.academic_year %}{{ offering.academic_year }}||{% endif %}{% endfor %}{% endcapture %}{% assign course_years = course_years_blob | split: "||" | uniq %}{% capture course_people_names_blob %}{% if course_relationships and course_relationships.related_people_entries %}{% for person_entry in course_relationships.related_people_entries %}{{ person_entry.person_name }}||{% endfor %}{% endif %}{% endcapture %}{% assign course_people_names = course_people_names_blob | split: "||" | uniq %}{% capture course_instructor_topics_blob %}{% if course_relationships and course_relationships.related_people_entries %}{% for person_entry in course_relationships.related_people_entries %}{% assign related_person = site.people | where: "slug", person_entry.slug | first %}{% if related_person %}{% for topic in related_person.related_topics %}{{ topic }}||{% endfor %}{% for area in related_person.research_areas %}{{ area }}||{% endfor %}{% endif %}{% assign external_person = external_people[person_entry.slug] %}{% if external_person and external_person.profiles %}{% for profile in external_person.profiles %}{% assign external_topics = profile.fields.research_topics.value %}{% if external_topics %}{% for topic in external_topics %}{{ topic }}||{% endfor %}{% endif %}{% endfor %}{% endif %}{% endfor %}{% endif %}{% endcapture %}{% assign course_instructor_topics = course_instructor_topics_blob | split: "||" | uniq %},
    {
      "id": {{ course.course_code | prepend: "course:" | jsonify }},
      "type": "course",
      "course_code": {{ course.course_code | jsonify }},
      "course_name": {{ course.course_name | jsonify }},
      "title": {{ course.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ course.summary | default: course.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "url": {{ course.url | absolute_url | jsonify }},
      "keywords": {% if course.keywords %}{{ course.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if course.aliases %}{{ course.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% if course_relationships and course_relationships.related_people %}{{ course_relationships.related_people | jsonify }}{% elsif course.related_people %}{{ course.related_people | jsonify }}{% else %}[]{% endif %},
      "related_people_names": {% if course_people_names %}{{ course_people_names | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% include related-course-codes.json codes=course.related_courses %},
      "related_groups": {% if course.related_groups %}{{ course.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if course.related_programs %}{{ course.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if course.related_topics %}{{ course.related_topics | jsonify }}{% else %}[]{% endif %},
      "instructors": {% if course_instructors %}{{ course_instructors | jsonify }}{% else %}[]{% endif %},
      "offerings_terms": {% if course_terms %}{{ course_terms | jsonify }}{% else %}[]{% endif %},
      "offerings_academic_years": {% if course_years %}{{ course_years | jsonify }}{% else %}[]{% endif %},
      "instructor_topics": {% if course_instructor_topics %}{{ course_instructor_topics | jsonify }}{% else %}[]{% endif %}
    }{% endfor %}{% assign job_pages = site.pages | default: empty_array | where_exp: "item", "item.url contains '/news_and_events/jobs_and_internships/'" | sort: "url" %}{% for resource_page in job_pages %},
    {
      "id": {{ "resource:" | append: resource_page.url | replace: "/", "" | jsonify }},
      "type": "resource",
      "title": {{ resource_page.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ resource_page.summary | default: resource_page.description | default: resource_page.content | markdownify | strip_html | normalize_whitespace | truncate: 220 | jsonify }},
      "url": {{ resource_page.url | absolute_url | jsonify }},
      "keywords": {% if resource_page.keywords %}{{ resource_page.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if resource_page.aliases %}{{ resource_page.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% if resource_page.related_people %}{{ resource_page.related_people | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% include related-course-codes.json codes=resource_page.related_courses %},
      "related_groups": {% if resource_page.related_groups %}{{ resource_page.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if resource_page.related_programs %}{{ resource_page.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if resource_page.related_topics %}{{ resource_page.related_topics | jsonify }}{% else %}[]{% endif %},
      "nav_label": {{ resource_page.nav_label | default: nil | jsonify }},
      "section_name": {{ resource_page.section_name | default: nil | jsonify }},
      "parent_section": {{ resource_page.parent_section | default: nil | jsonify }},
      "is_landing_page": {% if resource_page.is_landing_page %}true{% else %}false{% endif %},
      "menu_keywords": {% if resource_page.menu_keywords %}{{ resource_page.menu_keywords | jsonify }}{% else %}[]{% endif %}
    }{% endfor %}{% assign program_urls = "/undergraduate-programs|/graduate-programs|/honors-programs|/certificate-programs|/cs_ba|/cs_bs|/it_bs|/cs_ms|/cs_phd" | split: "|" %}{% for item_url in program_urls %}{% assign program_page = site.pages | where: "url", item_url | first %}{% if program_page %},
    {
      "id": {{ program_page.url | replace: "/", "" | prepend: "program:" | jsonify }},
      "type": "program",
      "title": {{ program_page.program_name | default: program_page.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ program_page.summary | default: program_page.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "url": {{ program_page.url | absolute_url | jsonify }},
      "keywords": {% if program_page.keywords %}{{ program_page.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if program_page.aliases %}{{ program_page.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% if program_page.related_people %}{{ program_page.related_people | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% include related-course-codes.json codes=program_page.related_courses %},
      "related_groups": {% if program_page.related_groups %}{{ program_page.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if program_page.related_programs %}{{ program_page.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if program_page.related_topics %}{{ program_page.related_topics | jsonify }}{% else %}[]{% endif %},
      "nav_label": {{ program_page.nav_label | default: nil | jsonify }},
      "section_name": {{ program_page.section_name | default: nil | jsonify }},
      "parent_section": {{ program_page.parent_section | default: nil | jsonify }},
      "is_landing_page": {% if program_page.is_landing_page %}true{% else %}false{% endif %},
      "menu_keywords": {% if program_page.menu_keywords %}{{ program_page.menu_keywords | jsonify }}{% else %}[]{% endif %}
    }{% endif %}{% endfor %}{% assign people_pages = site.people | default: empty_array | sort: "person_name" %}{% for person in people_pages %}{% assign person_relationships = offering_relationships.people[person.slug] %}{% assign external_person = external_people[person.slug] %}{% capture person_course_names_blob %}{% if person_relationships and person_relationships.related_course_entries %}{% for course_entry in person_relationships.related_course_entries %}{{ course_entry.course_name }}||{% endfor %}{% endif %}{% endcapture %}{% assign person_course_names = person_course_names_blob | split: "||" | uniq %}{% capture person_teaching_terms_blob %}{% if person_relationships and person_relationships.related_courses %}{% for related_code in person_relationships.related_courses %}{% assign related_offerings = offerings_data.course_index[related_code] | default: empty_array %}{% for offering in related_offerings %}{% assign instructor_match = offering_relationships.instructor_matches[offering.instructor] %}{% if instructor_match and instructor_match.slug == person.slug and offering.term_label %}{{ offering.term_label }}||{% endif %}{% endfor %}{% endfor %}{% endif %}{% endcapture %}{% assign person_teaching_terms = person_teaching_terms_blob | split: "||" | uniq %}{% capture person_teaching_years_blob %}{% if person_relationships and person_relationships.related_courses %}{% for related_code in person_relationships.related_courses %}{% assign related_offerings = offerings_data.course_index[related_code] | default: empty_array %}{% for offering in related_offerings %}{% assign instructor_match = offering_relationships.instructor_matches[offering.instructor] %}{% if instructor_match and instructor_match.slug == person.slug and offering.academic_year %}{{ offering.academic_year }}||{% endif %}{% endfor %}{% endfor %}{% endif %}{% endcapture %}{% assign person_teaching_years = person_teaching_years_blob | split: "||" | uniq %}{% capture external_research_topics_blob %}{% if external_person and external_person.profiles %}{% for profile in external_person.profiles %}{% assign ext_topics = profile.fields.research_topics.value %}{% if ext_topics %}{% for topic in ext_topics %}{{ topic }}||{% endfor %}{% endif %}{% endfor %}{% endif %}{% endcapture %}{% assign external_research_topics = external_research_topics_blob | split: "||" | uniq %}{% capture external_lab_group_blob %}{% if external_person and external_person.profiles %}{% for profile in external_person.profiles %}{% assign ext_lab = profile.fields.lab_or_group.value %}{% if ext_lab %}{{ ext_lab }}||{% endif %}{% endfor %}{% endif %}{% endcapture %}{% assign external_lab_groups = external_lab_group_blob | split: "||" | uniq %}{% capture external_profile_links_blob %}{% if external_person and external_person.profiles %}{% for profile in external_person.profiles %}{% assign ext_profile_links = profile.fields.profile_links.value %}{% if ext_profile_links %}{% for link in ext_profile_links %}{% if link.label %}{{ link.label }}||{% endif %}{{ link.url }}||{% endfor %}{% endif %}{% endfor %}{% endif %}{% endcapture %}{% assign external_profile_links = external_profile_links_blob | split: "||" | uniq %}{% capture external_recent_news_blob %}{% if external_person and external_person.profiles %}{% for profile in external_person.profiles %}{% assign ext_news = profile.fields.recent_news_titles.value %}{% if ext_news %}{% for item in ext_news %}{{ item }}||{% endfor %}{% endif %}{% endfor %}{% endif %}{% endcapture %}{% assign external_recent_news = external_recent_news_blob | split: "||" | uniq %},
    {
      "id": {{ person.slug | prepend: "person:" | jsonify }},
      "type": "person",
      "person_name": {{ person.person_name | default: person.title | strip_html | normalize_whitespace | jsonify }},
      "title": {{ person.person_name | default: person.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ person.summary | default: person.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "url": {{ person.url | absolute_url | jsonify }},
      "job_title": {{ person.job_title | default: "" | jsonify }},
      "keywords": {% if person.keywords %}{{ person.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if person.aliases %}{{ person.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% if person.related_people %}{{ person.related_people | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% if person_relationships and person_relationships.related_courses %}{{ person_relationships.related_courses | jsonify }}{% else %}{% include related-course-codes.json codes=person.related_courses %}{% endif %},
      "related_groups": {% if person.related_groups %}{{ person.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if person.related_programs %}{{ person.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if person.related_topics %}{{ person.related_topics | jsonify }}{% elsif person.research_areas %}{{ person.research_areas | jsonify }}{% else %}[]{% endif %},
      "research_areas": {% if person.research_areas %}{{ person.research_areas | jsonify }}{% else %}[]{% endif %},
      "teaches_courses": {% if person_course_names %}{{ person_course_names | jsonify }}{% else %}[]{% endif %},
      "current_teaching_terms": {% if person_teaching_terms %}{{ person_teaching_terms | jsonify }}{% else %}[]{% endif %},
      "teaching_academic_years": {% if person_teaching_years %}{{ person_teaching_years | jsonify }}{% else %}[]{% endif %},
      "external_research_topics": {% if external_research_topics %}{{ external_research_topics | jsonify }}{% else %}[]{% endif %},
      "lab_or_group": {% if external_lab_groups %}{{ external_lab_groups | jsonify }}{% else %}[]{% endif %},
      "profile_links": {% if external_profile_links %}{{ external_profile_links | jsonify }}{% else %}[]{% endif %},
      "source_urls": {% if external_person and external_person.source_urls %}{{ external_person.source_urls | jsonify }}{% elsif person.same_as %}{{ person.same_as | jsonify }}{% else %}[]{% endif %},
      "recent_news_titles": {% if external_recent_news %}{{ external_recent_news | jsonify }}{% else %}[]{% endif %}
    }{% endfor %}{% assign group_pages = site.groups | default: empty_array | sort: "group_name" %}{% for group in group_pages %},
    {
      "id": {{ group.slug | prepend: "group:" | jsonify }},
      "type": "group",
      "title": {{ group.group_name | default: group.title | strip_html | normalize_whitespace | jsonify }},
      "summary": {{ group.summary | default: group.description | default: "" | strip_html | normalize_whitespace | jsonify }},
      "url": {{ group.url | absolute_url | jsonify }},
      "keywords": {% if group.keywords %}{{ group.keywords | jsonify }}{% else %}[]{% endif %},
      "aliases": {% if group.aliases %}{{ group.aliases | jsonify }}{% else %}[]{% endif %},
      "related_people": {% assign group_people = group.related_people | default: group.lead_people %}{% if group_people %}{{ group_people | jsonify }}{% else %}[]{% endif %},
      "related_courses": {% include related-course-codes.json codes=group.related_courses %},
      "related_groups": {% if group.related_groups %}{{ group.related_groups | jsonify }}{% else %}[]{% endif %},
      "related_programs": {% if group.related_programs %}{{ group.related_programs | jsonify }}{% else %}[]{% endif %},
      "related_topics": {% if group.related_topics %}{{ group.related_topics | jsonify }}{% else %}[]{% endif %}
    }{% endfor %}
  ]
}
