---
layout: null
permalink: /courses.json
---
{
{% assign empty_array = "" | split: "" %}
{% assign course_pages = site.pages | default: empty_array | where_exp: "item", "item.course_code" | sort: "course_code" %}
{% for course in course_pages %}
  {{ course.course_code | jsonify }}: {
    "title": {{ course.course_name | default: course.title | jsonify }},
    "url": {{ course.url | relative_url | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
}
